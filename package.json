{
  "name": "cubism",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev:desktop": "pnpm --filter desktop dev",
    "dev:renderer": "pnpm --filter renderer dev",
    "dev:socket": "pnpm --filter socket-server dev",
    "dev": "concurrently -n socket,desktop,renderer -c magenta,cyan,green \"pnpm dev:socket\" \"pnpm dev:desktop\" \"pnpm dev:renderer\"",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "concurrently": "latest",
    "typescript": "latest"
  }
}
